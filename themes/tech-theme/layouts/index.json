{{- $pages := where .Site.RegularPages "Type" "in" (slice "ai-infra" "agent" "llm") -}}
{{- $pages = where $pages "Params.draft" "ne" true -}}
{
  "title": "{{ .Site.Title }}",
  "description": "{{ .Site.Params.description }}",
  "baseURL": "{{ .Site.BaseURL }}",
  "posts": [
    {{- range $index, $page := $pages -}}
    {{- if gt $index 0 }},{{ end }}
    {
      "title": {{ $page.Title | jsonify }},
      "url": "{{ $page.RelPermalink }}",
      "date": "{{ $page.Date.Format "2006-01-02" }}",
      "category": {{ with $page.Params.category }}{{ . | jsonify }}{{ else }}""{{ end }},
      "tags": {{ with $page.Params.tags }}{{ . | jsonify }}{{ else }}[]{{ end }},
      "summary": {{ $page.Summary | plainify | jsonify }}
    }
    {{- end -}}
  ]
}